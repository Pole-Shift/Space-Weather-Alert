<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/w_flux_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_flux_label"
        android:textColor="@color/cyan"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/w_flux_class"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="@color/green"
        android:textSize="40sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:shadowColor="#8000FF62"
        android:shadowRadius="14"
        android:shadowDx="0"
        android:shadowDy="0" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#3300FF62" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_lastm_label"
        android:textColor="@color/amber"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:fontFamily="monospace" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/w_lastm_class"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="none"
            android:textColor="@color/amber"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/w_lastm_time"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/w_updated"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="updated —"
            android:textColor="@color/muted"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <ImageView
            android:id="@+id/w_refresh"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="@string/refresh" />
    </LinearLayout>
</LinearLayout>
